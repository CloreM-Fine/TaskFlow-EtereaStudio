# =====================================================
# TASKFLOW - CONFIGURAZIONE AMBIENTE
# Copia questo file in .env e compila i valori reali
# NON committare il file .env!
# =====================================================

# -----------------------------------------------------
# DATABASE - SiteGround
# -----------------------------------------------------
DB_HOST=localhost
DB_NAME=dbxs46wroi3714
DB_USER=ub7fszgir5zwg
DB_PASS=your_secure_password_here

# -----------------------------------------------------
# SICUREZZA - Password e Chiavi
# -----------------------------------------------------

# Password per accesso sezione Tasse (hash bcrypt)
# Generare con: php -r "echo password_hash('tua_password', PASSWORD_BCRYPT);"
# IMPORTANTE: Generare l'hash con: php -r "echo password_hash('Lorenzo2026!', PASSWORD_BCRYPT);"
# L'hash qui sotto è un placeholder - sostituirlo con l'hash reale generato dal comando sopra
TASSE_PASSWORD_HASH=Lorenzo2026!

# Chiave segreta per CSRF Token (generare valore casuale di 32+ char)
CSRF_SECRET_KEY=change_this_to_a_random_32_char_string

# Chiave per crittografia dati sensibili (se necessario)
# Generare con: openssl rand -base64 32
ENCRYPTION_KEY=change_this_to_a_base64_32_char_key

# -----------------------------------------------------
# API ESTERNE
# -----------------------------------------------------

# OpenAI API Key (opzionale)
OPENAI_API_KEY=sk-your_openai_api_key_here

# -----------------------------------------------------
# CONFIGURAZIONE APPLICAZIONE
# -----------------------------------------------------

# Ambiente: production | development
APP_ENV=production

# URL base dell'applicazione
BASE_URL=https://taskflow.it

# Debug: true | false (solo per development!)
APP_DEBUG=false

# -----------------------------------------------------
# SESSIONE E SICUREZZA
# -----------------------------------------------------

# Durata sessione in secondi (default: 2 ore = 7200)
SESSION_LIFETIME=7200

# Durata cookie in secondi (default: 30 giorni = 2592000)
COOKIE_LIFETIME=2592000

# Tentativi login falliti prima del blocco (default: 20 - permissivo)
MAX_LOGIN_ATTEMPTS=20

# Durata blocco login in minuti (default: 5 - blocco breve)
LOGIN_LOCKOUT_MINUTES=5

# -----------------------------------------------------
# UPLOAD E FILE
# -----------------------------------------------------

# Dimensione massima upload in MB (default: 10)
MAX_UPLOAD_SIZE_MB=10

# Tipi MIME consentiti per upload (separati da virgola)
ALLOWED_UPLOAD_TYPES=application/pdf,image/jpeg,image/png,image/webp,image/svg+xml
